{
  "name": "quill",
  "version": "0.1.0",
  "description": "Open-source meeting notetaker. Captures system audio + mic, transcribes via Whisper, enhances notes with AI templates.",
  "main": "out/main/index.js",
  "type": "module",
  "author": "maewa-space",
  "license": "MIT",
  "homepage": "https://github.com/maewa-space/quill",
  "repository": {
    "type": "git",
    "url": "https://github.com/maewa-space/quill.git"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "icons": "node scripts/build-icons.mjs",
    "package": "electron-vite build && electron-builder --mac --config electron-builder.yml",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/newsreader": "^5.2.10",
    "@tiptap/extension-placeholder": "^2.10.3",
    "@tiptap/extension-typography": "^2.10.3",
    "@tiptap/pm": "^2.10.3",
    "@tiptap/react": "^2.10.3",
    "@tiptap/starter-kit": "^2.10.3",
    "audiotee": "^0.0.7",
    "better-sqlite3": "^11.5.0",
    "clsx": "^2.1.1",
    "electron-audio-loopback": "^1.0.6",
    "lucide-react": "^0.460.0",
    "motion": "^12.38.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "eslint": "^9.16.0",
    "playwright": "^1.49.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "vitest": "^2.1.6"
  }
}
